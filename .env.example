# ========= App =========
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=local

# ========= Supabase =========
# Project URL (e.g. https://<ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVICE ROLE — only on server, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres URLs for Drizzle migrations / server queries.
# Pooled connection for app runtime, direct for migrations.
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres
DIRECT_DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres

# ========= Anthropic =========
ANTHROPIC_API_KEY=

# Opus for high-stakes classifiers, Sonnet for drafters, Haiku for routing.
ANTHROPIC_MODEL_OPUS=claude-opus-4-7
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001

# ========= Razorpay =========
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ========= WhatsApp (WATI) =========
WATI_API_KEY=
WATI_BASE_URL=
WATI_WEBHOOK_SECRET=

# ========= SMS OTP (MSG91 fallback) =========
MSG91_AUTH_KEY=
MSG91_SENDER_ID=SRKSHA
MSG91_OTP_TEMPLATE_ID=

# ========= Trigger.dev =========
# Background job runtime (analyse pipeline + future async work). See ADR 0008.
# Get keys at https://cloud.trigger.dev → project surakshasaathi → API Keys.
#   - tr_dev_*  for local + Vercel Preview + Vercel Development
#   - tr_prod_* for Vercel Production only
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=proj_afbawgljgtebkvjvpiws
TRIGGER_API_URL=https://api.trigger.dev

# ========= Observability =========
# Server DSN (Route handlers, Server Actions, middleware) — never expose.
SENTRY_DSN=
# Public DSN the browser bundle reads; can be the same project as SENTRY_DSN.
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload credentials (CI only).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Optional separate project for the admin portal; falls back to SENTRY_PROJECT.
SENTRY_PROJECT_ADMIN=

# ========= Admin bootstrap =========
# Any user who authenticates with this email is auto-promoted to a super_admin
# membership on the default tenant. Works in any environment.
#
# UAT: admin-uat@surakshasaathi.com (or similar test inbox).
# Prod: a single tightly-controlled inbox with 2FA. Unset this variable in
# prod once human admins have been granted via the admin portal — the variable
# is intentionally a foot-gun and should be retired as soon as it's no longer
# needed.
ADMIN_BOOTSTRAP_EMAIL=admin-uat@surakshasaathi.com
