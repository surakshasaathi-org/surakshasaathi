{
  "name": "@suraksha/db",
  "version": "0.1.0",
  "private": true,
  "description": "Postgres schema and clients (Supabase). Drizzle-based. Multi-tenant with RLS.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts",
    "./seed": "./src/seed/index.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@suraksha/types": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "pg": "^8.13.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
