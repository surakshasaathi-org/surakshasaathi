{
  "name": "@suraksha/i18n",
  "version": "0.1.0",
  "private": true,
  "description": "i18n infra for SurakshaSaathi. Locales, namespaces, and the insurance glossary.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./glossary": "./src/glossary.ts",
    "./config": "./src/config.ts"
  },
  "scripts": {
    "check": "tsx scripts/check-completeness.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@suraksha/types": "workspace:*",
    "next-intl": "^3.26.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
