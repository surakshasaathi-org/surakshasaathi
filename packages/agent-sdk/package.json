{
  "name": "@suraksha/agent-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Anthropic-backed agent runtime. Tiered model routing, prompt caching, tool registry, agent_run persistence.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./registry": "./src/registry.ts",
    "./run": "./src/run.ts",
    "./pricing": "./src/pricing.ts",
    "./router": "./src/router.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@google/generative-ai": "^0.21.0",
    "@suraksha/db": "workspace:*",
    "@suraksha/types": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^2.1.0",
    "typescript": "^5.5.4"
  }
}
