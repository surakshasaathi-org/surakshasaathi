{
  "name": "@suraksha/eval-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Eval Lab platform infrastructure: synthetic dataset generation, full agent tracing, DB-backed prod sampling, batch run orchestration. Agent-slug-driven so new product lines plug in via templates + rubrics, not code changes.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./templates": "./src/templates/index.ts",
    "./generator": "./src/generator/index.ts",
    "./runtime": "./src/runtime/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@suraksha/db": "workspace:*",
    "@suraksha/types": "workspace:*",
    "@faker-js/faker": "^9.2.0",
    "drizzle-orm": "^0.36.4",
    "seedrandom": "^3.0.5"
  },
  "devDependencies": {
    "@types/seedrandom": "^3.0.8",
    "vitest": "^2.1.5",
    "typescript": "^5.5.4"
  }
