{
  "name": "@suraksha/web-customer",
  "version": "0.1.0",
  "private": true,
  "description": "Public-facing customer web app — surakshasaathi.com. 8 product modules, multi-locale, DB-driven landing page.",
  "type": "module",
  "scripts": {
    "dev": "unset ANTHROPIC_API_KEY ANTHROPIC_BASE_URL && next dev --port 3000",
    "build": "next build",
    "start": "unset ANTHROPIC_API_KEY ANTHROPIC_BASE_URL && next start --port 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf .next .turbo"
  },
  "dependencies": {
    "@suraksha/types": "workspace:*",
    "@suraksha/db": "workspace:*",
    "@suraksha/i18n": "workspace:*",
    "@suraksha/ui": "workspace:*",
    "@suraksha/access-control": "workspace:*",
    "@suraksha/agent-sdk": "workspace:*",
    "@suraksha/eval-lab": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "zod": "^3.23.8",
    "@sentry/nextjs": "^8.42.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "@trigger.dev/sdk": "^4.4.6",
    "lucide-react": "^0.454.0",
    "next": "^15.0.3",
    "next-intl": "^3.26.0",
    "react": "^19.0.0-rc-02c0e824-20241028",
    "react-dom": "^19.0.0-rc-02c0e824-20241028"
  },
  "devDependencies": {
    "@trigger.dev/build": "^4.4.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.5.4",
    "vitest": "^2.1.5"
  }
}
